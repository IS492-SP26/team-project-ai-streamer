# Example environment variables (DO NOT include secrets in repo)

# Path to local SQLite file used for telemetry (default)
DATABASE_URL=app/data/telemetry.db

# Model API key placeholder (do not commit real keys)
MODEL_API_KEY_PLACEHOLDER=

# Streamlit dev server port (if using frontend)
STREAMLIT_PORT=8501

# Other runtime config
LOG_LEVEL=INFO
